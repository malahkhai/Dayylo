{
    "cli": {
        "appVersionSource": "remote"
    },
    "build": {
        "development": {
            "developmentClient": true,
            "distribution": "internal",
            "ios": {
                "simulator": false
            }
        },
        "preview": {
            "distribution": "internal"
        },
        "production": {
            "autoIncrement": true,
            "autoSubmit": true
        }
    },
    "submit": {
        "production": {
            "ios": {
                "appleId": "YOUR_APPLE_ID@email.com",
                "ascAppId": "YOUR_APP_STORE_CONNECT_APP_ID",
                "appleTeamId": "YOUR_APPLE_TEAM_ID"
            }
        }
    }
}